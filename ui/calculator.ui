    <string notr="true">QPushButton {
    min-width: 60px;
    max-width: 60px;
    min-height: 60px;
    max-height: 60px;
    border-radius: 5px; /* 順便加個小圓角會更好看 */
    background-color: #f0f0f0;
    border: 1px solid #c0c0c0;
}

/* 滑鼠移上去變色 */
QPushButton:hover {
    background-color: #e0e0e0;
}

/* 按下去變色 */
QPushButton:pressed {
    background-color: #d0d0d0;
}
/* 基礎樣式 */
QPushButton { ... }

/* 針對特定按鈕變色 (使用物體名稱) */
QPushButton#equal_Button {
    background-color: #0078d4;
    color: white;
}

QPushButton#Add_Button, QPushButton#Subtraction_Button {
    background-color: #e1e1e1;
}</string>
