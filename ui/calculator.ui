           <widget class="QCheckBox" name="REC_Check">
            <property name="styleSheet">
             <string notr="true">/* 1. 設定文字與間距 */
QCheckBox {
    spacing: 8px;
    color: #333333;
    font-weight: bold;
}

/* 2. 定義外圈（圓形容器） */
QCheckBox::indicator {
    width: 10px;
    height: 10px;
    border-radius: 14px; /* 半徑為寬高的一半以上，強制變圓形 */
    border: 2px solid #999999;
    background-color: #ffffff;
}

/* 3. 未選取狀態：紅色實心正方形 (停止錄製圖示) */
QCheckBox::indicator:unchecked {
    background-color: #cc0000; /* 紅色 */
    /* 關鍵技巧：用 6px 的厚邊框（顏色需跟背景 #f3f3f3 一致） */
    /* 邊框會往內擠壓背景色，背景色區域就會變成正方形 */
    border: 7px solid #f3f3f3; 
}

/* 4. 選取狀態：紅色雙垂直線 (錄製/暫停圖示) */
QCheckBox::indicator:checked {
    background-color: white;
    border: 2px solid #cc0000; /* 外圈變紅 */
    /* 使用線性漸層在背景畫出兩條垂直紅線 */
    background-image: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, 
        stop:0.20 transparent, 
        stop:0.21 #cc0000, stop:0.40 #cc0000, 
        stop:0.41 transparent, stop:0.59 transparent, 
        stop:0.60 #cc0000, stop:0.79 #cc0000, 
        stop:0.80 transparent);
}

/* 5. 滑鼠移過時的微調 */
QCheckBox::indicator:hover {
    border: 2px solid #555555;
}</string>
            </property>
