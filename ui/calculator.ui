  <property name="styleSheet">
   <string notr="true">/* 全域背景設定 */
#centralwidget {
    background-color: #f3f3f3; /* 淺灰色背景，看起來比較高級 */
}

/* 螢幕 (QLineEdit) 樣式 */
QLineEdit {
    background-color: transparent;
    border: 2px solid #7a7a7a; /* 深灰色實線邊框，2像素寬 */
    border-radius: 4px;        /* 與按鈕一致的圓角 */
    color: #1a1a1a;
    font-family: &quot;Segoe UI&quot;, &quot;Microsoft JhengHei&quot;;
    font-size: 40px; /* 大數字顯示 */
    font-weight: bold;
    padding: 10px;
}

/* 上方小標籤 (QLabel) 樣式 */
QLabel#label {
    color: #666666;
    font-family: &quot;Segoe UI&quot;;
    font-size: 14px;
    padding-right: 15px;
}

/* 基礎按鈕樣式 (所有按鈕共通) */
QPushButton {
    background-color: #ffffff; /* 預設白色 */
    border: 1px solid #e5e5e5;
    border-radius: 4px; /* 輕微圓角 */
    font-family: &quot;Segoe UI&quot;, &quot;Microsoft JhengHei&quot;;
    font-size: 16px;
    color: #1a1a1a;
}

/* 滑鼠移入變色 */
QPushButton:hover {
    background-color: #f9f9f9;
    border: 1px solid #d0d0d0;
}

/* 按下時變色 */
QPushButton:pressed {
    background-color: #eeeeee;
}

/* 運算符按鈕 (使用物體名稱來指定特定的按鈕) */
QPushButton#Add_Button, QPushButton#Subtraction_Button, 
QPushButton#Multiplication_Button, QPushButton#Division_Button,
QPushButton#Back_Button, QPushButton#Clear_Button, QPushButton#Clear_Entry_Buttom {
    background-color: #fafafa;
    font-weight: bold;
    color: #0078d4; /* 運算符用藍色強調 */
}

/* 等於按鈕 (突出的重點色) */
QPushButton#equal_Button {
    background-color: #0078d4;
    color: white;
    border: none;
}

QPushButton#equal_Button:hover {
    background-color: #006abc;
}

QPushButton#equal_Button:pressed {
    background-color: #005a9e;
}

/* 科學面板按鈕 (稍微低調一點的顏色) */
#scientific_panel QPushButton {
    background-color: #fbfbfb;
    font-size: 13px;
    color: #555555;
}

/* 單選鈕 (RadioButton) 樣式 */
QRadioButton {
    font-family: &quot;Segoe UI&quot;;
    font-size: 12px;
    color: #333333;
    spacing: 5px;
}</string>
